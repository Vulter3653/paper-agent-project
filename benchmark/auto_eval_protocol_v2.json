{
  "benchmark_name": "Benchmark Standard v2: Automated Evaluation Protocol for Traceable Scholarly Discovery",
  "human_evaluation": false,
  "task_count": 20,
  "methods": ["rule_based", "single_llm", "proposed_agent"],
  "primary_metrics": ["precision_at_5", "ndcg_at_5", "recall_at_20", "doi_exact_match_rate", "paper_existence_rate", "hallucination_rate"],
  "secondary_metrics": ["llm_judge_relevance_score", "trace_completeness_rate", "latency", "cost_proxy"],
  "reproducibility_controls": [
    "frozen_prompts",
    "model_identifier",
    "temperature",
    "top_p",
    "seed_if_supported",
    "input_files",
    "output_schema",
    "run_timestamp"
  ],
  "judge_protocol": {
    "prompt_file": "benchmark/llm_judge_prompt_v2.md",
    "temperature": 0.0,
    "scale": "1-5",
    "required_fields": ["relevance_score_v2", "construct_match", "context_match", "method_domain_match", "reason", "confidence"]
  }
}
