{
  "name": "paper-agent-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:worker": "npm run dev --workspace apps/worker",
    "dev:mcp": "npm run dev --workspace apps/mcp",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace apps/web",
    "deploy:web": "npm run deploy --workspace apps/web",
    "deploy:worker": "npm run deploy --workspace apps/worker",
    "deploy:mcp": "npm run deploy --workspace apps/mcp",
    "benchmark:evaluate-proposed": "node benchmark/scripts/evaluate-proposed-agent.mjs",
    "benchmark:compare-baselines": "node benchmark/scripts/compare-baselines.mjs",
    "benchmark:audit-gold": "node benchmark/scripts/audit-gold-labels.mjs",
    "benchmark:refine-gold": "node benchmark/scripts/refine-gold-candidates.mjs",
    "benchmark:run-proposed": "node benchmark/scripts/run-proposed-agent.mjs",
    "benchmark:run-expanded": "node benchmark/scripts/run-proposed-agent.mjs --output benchmark/proposed_agent_results_expanded.csv --jobs-output benchmark/proposed_agent_jobs_expanded.csv",
    "benchmark:run-expanded-retry": "node benchmark/scripts/run-proposed-agent.mjs --start 8 --limit 12 --output benchmark/proposed_agent_results_expanded_retry_t009_t020.csv --jobs-output benchmark/proposed_agent_jobs_expanded_retry_t009_t020.csv --poll-ms 10000 --delay-ms 5000 --max-results 10",
    "benchmark:prepare-expanded-dry-run": "node benchmark/scripts/prepare-limited-dry-run-command.mjs --scope T004-T018 --mode plan",
    "benchmark:limited-dry-run:plan": "node benchmark/scripts/run-limited-batch-dry-run.mjs --scope T004-T006 --mode plan",
    "benchmark:limited-dry-run:preflight": "node benchmark/scripts/run-limited-batch-dry-run.mjs --scope T004-T006 --mode preflight",
    "benchmark:score-gold": "node benchmark/scripts/score-gold-candidates.mjs",
    "benchmark:verify-gold": "node benchmark/scripts/verify-gold-crossref.mjs",
    "e2e:reports": "npm run e2e --workspace apps/mcp",
    "smoke:worker": "npm run smoke --workspace apps/worker",
    "smoke:mcp": "npm run smoke --workspace apps/mcp",
    "typecheck": "npm run typecheck --workspaces",
    "validate:agent-rules": "node scripts/validate-agent-rules.mjs",
    "validate:history": "node scripts/validate-history-integrity.mjs",
    "build:web:staging": "npm run build:staging --workspace apps/web",
    "deploy:web:staging": "npm run deploy:staging --workspace apps/web",
    "deploy:worker:staging": "npm run deploy:staging --workspace apps/worker",
    "deploy:mcp:staging": "npm run deploy:staging --workspace apps/mcp",
    "smoke:worker:staging": "WORKER_URL=${STAGING_WORKER_URL:-https://paper-agent-project-staging.shch3653.workers.dev} npm run smoke:worker",
    "smoke:mcp:staging": "MCP_URL=${STAGING_MCP_URL:-https://paper-agent-mcp-staging.shch3653.workers.dev/mcp} npm run smoke:mcp",
    "staging:check": "npm run typecheck && npm run build:web:staging && npm run smoke:worker:staging && npm run smoke:mcp:staging",
    "dev:worker:local": "npm run dev --workspace apps/worker -- --port 8787",
    "smoke:worker:local": "WORKER_URL=http://localhost:8787 REQUIRE_READY=false npm run smoke:worker",
    "benchmark:auto-review-baselines": "node benchmark/scripts/auto-review-baselines.mjs",
    "benchmark:v3:normalize": "node benchmark/scripts/normalize-results-v3.mjs",
    "benchmark:v3:layer1": "node benchmark/scripts/compute-layer1-foundation-v3.mjs",
    "benchmark:v3:layer2": "node benchmark/scripts/compute-layer2-schema-v3.mjs",
    "benchmark:v3:layer3": "node benchmark/scripts/compute-layer3-validity-v3.mjs",
    "benchmark:v3:layer4": "node benchmark/scripts/compute-layer4-retrieval-v3.mjs",
    "benchmark:v3:layer5:prepare": "node benchmark/scripts/prepare-layer5-judge-input-v3.mjs",
    "benchmark:v3:layer5:run": "node benchmark/scripts/run-layer5-llm-judge-v3.mjs",
    "benchmark:v3:layer5:retry": "node benchmark/scripts/retry-layer5-failed-judge-v3.mjs",
    "benchmark:v3:layer5:compute": "node benchmark/scripts/compute-layer5-semantic-v3.mjs",
    "benchmark:v3:layer5": "npm run benchmark:v3:layer5:prepare && npm run benchmark:v3:layer5:run && npm run benchmark:v3:layer5:compute",
    "benchmark:v3:layer6": "node benchmark/scripts/compute-layer6-robustness-v3.mjs",
    "benchmark:v3:baseline-support": "node benchmark/scripts/compute-baseline-support-matrix-v3.mjs",
    "benchmark:v3:layer5:representativeness": "node benchmark/scripts/compute-layer5-representativeness-v3.mjs",
    "benchmark:v3:layer5:proxy": "node benchmark/scripts/compute-layer5-deterministic-semantic-proxy-v3.mjs",
    "benchmark:v3:supplements": "npm run benchmark:v3:baseline-support && npm run benchmark:v3:layer5:representativeness && npm run benchmark:v3:layer5:proxy",
    "benchmark:v3:summary": "node benchmark/scripts/compute-benchmark-v3-deterministic-summary.mjs",
    "benchmark:v3:check": "node benchmark/scripts/check-v3-deterministic-validation.mjs",
    "benchmark:v3:deterministic": "npm run benchmark:v3:normalize && npm run benchmark:v3:layer1 && npm run benchmark:v3:layer2 && npm run benchmark:v3:layer3 && npm run benchmark:v3:layer4 && npm run benchmark:v3:layer6 && npm run benchmark:v3:summary && npm run benchmark:v3:check",
    "benchmark:v3:full": "npm run benchmark:v3:deterministic && npm run benchmark:v3:layer5 && npm run benchmark:v3:summary && npm run benchmark:v3:check"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
